FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install \
    "feast[redis,postgres]" \
    psycopg2-binary \
    azure-storage-blob \
    adlfs

WORKDIR /app

COPY feast_repo/ ./feast_repo/
COPY scripts/feast_materialize.py ./scripts/

CMD ["python", "scripts/feast_materialize.py"]